{
  "id": 8,
  "type": "bargauge",
  "title": "Most played games the past 7 days",
  "gridPos": {
    "x": 0,
    "y": 24,
    "h": 8,
    "w": 12
  },
  "fieldConfig": {
    "defaults": {
      "mappings": [],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "semi-dark-orange",
            "value": null
          },
          {
            "color": "dark-green",
            "value": 5
          }
        ]
      },
      "color": {
        "mode": "thresholds"
      },
      "displayName": "${__field.labels.game}"
    },
    "overrides": []
  },
  "transformations": [
    {
      "id": "labelsToFields",
      "options": {
        "mode": "columns",
        "valueLabel": "game"
      }
    },
    {
      "id": "reduce",
      "options": {
        "includeTimeField": false,
        "labelsToFields": true,
        "mode": "seriesToRows",
        "reducers": [
          "last"
        ]
      }
    },
    {
      "id": "sortBy",
      "options": {
        "fields": {},
        "sort": [
          {
            "desc": true,
            "field": "Last"
          }
        ]
      }
    }
  ],
  "pluginVersion": "12.3.0",
  "targets": [
    {
      "alias": "",
      "datasource": {
        "type": "influxdb",
        "uid": "ffj5j02qepfcwc"
      },
      "hide": false,
      "query": "SELECT count(distinct(\"session_count\")) \nFROM \"steamdeck\".\"autogen\".\"playtime\" \nWHERE $timeFilter \nGROUP BY \"game\"",
      "rawQuery": true,
      "refId": "A",
      "resultFormat": "logs"
    }
  ],
  "datasource": {
    "type": "influxdb",
    "uid": "ffj5j02qepfcwc"
  },
  "options": {
    "reduceOptions": {
      "values": true,
      "calcs": [
        "last"
      ],
      "fields": ""
    },
    "orientation": "horizontal",
    "legend": {
      "showLegend": false,
      "displayMode": "table",
      "placement": "bottom",
      "calcs": []
    },
    "displayMode": "gradient",
    "valueMode": "color",
    "namePlacement": "auto",
    "showUnfilled": true,
    "sizing": "auto",
    "minVizWidth": 8,
    "minVizHeight": 16,
    "maxVizHeight": 300
  },
  "timeFrom": "now/w"
}
