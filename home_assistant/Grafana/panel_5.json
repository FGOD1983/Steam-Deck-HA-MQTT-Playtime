      "hide": false,
      "query": "SELECT \n  count(distinct(\"session_count\")) AS \"sessions\", \n  last(\"last_played\") AS \"last_played\"\nFROM \"steamdeck\".\"autogen\".\"playtime\" \nWHERE $timeFilter \nGROUP BY \"game\"",
